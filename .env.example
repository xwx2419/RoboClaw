# Copy this file to .env and fill in your real secrets.

# OpenAI / OpenAI-compatible runtime
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.4
OPENAI_WIRE_API=responses
OPENAI_REASONING_EFFORT=low
OPENAI_ORGANIZATION=
OPENAI_ORGANIZATION_NAME=ConfiguredOrganization
OPENAI_PROJECT=
OPENAI_PROJECT_NAME=ConfiguredProject
OPENAI_MODEL_CONTEXT_WINDOW=256000
OPENAI_MODEL_AUTO_COMPACT_TOKEN_LIMIT=128000

# Feishu bot app (long connection only, optional)
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_API_BASE=https://open.feishu.cn/open-apis
FEISHU_EVENT_RECEIVER=long_connection
FEISHU_SDK_LOG_LEVEL=INFO
